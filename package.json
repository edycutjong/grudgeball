{
  "private": true,
  "name": "grudgeball",
  "version": "1.1.0",
  "description": "🪤 Daily marble-drop gauntlet where the board is built from other players' grudges — Reddit Games with a Hook (Devvit)",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/edycutjong/grudgeball.git"
  },
  "homepage": "https://github.com/edycutjong/grudgeball#readme",
  "bugs": {
    "url": "https://github.com/edycutjong/grudgeball/issues"
  },
  "type": "module",
  "scripts": {
    "build": "vite build",
    "deploy": "npm run type-check && devvit upload",
    "dev": "devvit playtest",
    "launch": "npm run deploy && devvit publish",
    "login": "devvit login",
    "type-check": "tsc --build && tsc -p tsconfig.test.json",
    "lint": "eslint .",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage --silent",
    "ci": "npm run lint && npm run type-check && npm run test:coverage && npm run build",
    "seed:local": "tsx scripts/seed-local.ts",
    "check:submission": "node scripts/check_submission_readiness.mjs",
    "check:readiness": "node scripts/check_submission_readiness.mjs",
    "release": "semantic-release"
  },
  "engines": {
    "node": ">=22.2.0"
  },
  "dependencies": {
    "@devvit/start": "0.13.8",
    "@devvit/web": "0.13.8",
    "@hono/node-server": "2.0.6",
    "devvit": "0.13.8",
    "hono": "4.12.27",
    "phaser": "4.2.1"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.5",
    "@semantic-release/changelog": "^6.0.3",
    "@semantic-release/commit-analyzer": "^13.0.1",
    "@semantic-release/git": "^10.0.1",
    "@semantic-release/github": "^12.0.9",
    "@semantic-release/npm": "^13.1.5",
    "@semantic-release/release-notes-generator": "^14.1.1",
    "@types/node": "^22.19.19",
    "@vitest/coverage-v8": "^4.1.10",
    "eslint": "^9.39.5",
    "globals": "^16.5.0",
    "semantic-release": "^25.0.7",
    "tsx": "^4.20.0",
    "typescript": "6.0.3",
    "typescript-eslint": "^8.64.0",
    "vite": "8.1.0",
    "vitest": "^4.0.0"
  },
  "overrides": {
    "tmp": "^0.2.7",
    "ws": "^8.21.0",
    "protobufjs": "^7.6.5",
    "js-yaml": "^4.3.0"
  }
}
